{
  "name": "cravab",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "private": true,
  "scripts": {
    "dev": "npm run validate:env && next dev -p 3000",
    "dev:clean": "powershell -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }; if (Test-Path .next/cache) { Remove-Item -Recurse -Force .next/cache }\" && next dev -p 3000",
    "dev:reset": "powershell -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }; if (Test-Path node_modules/.cache) { Remove-Item -Recurse -Force node_modules/.cache }; if (Test-Path .next/cache) { Remove-Item -Recurse -Force .next/cache }\" && npm run dev",
    "dev:optimized": "NODE_OPTIONS=\"--max-old-space-size=4096\" next dev -p 3000",
    "build": "npm run validate:env && next build --webpack",
    "type-check": "tsc --noEmit",
    "build:production": "NODE_ENV=production npm run validate:env && next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:coverage": "jest --coverage",
    "test:pwa": "node scripts/test-pwa.js",
    "verify:https": "node scripts/verify-https-config.js",
    "verify:caching": "node scripts/verify-caching-system.js",
    "generate:icons": "node scripts/generate-icons-node.js",
    "generate:icons:production": "node scripts/generate-icons-production.js",
    "generate:ios-assets": "node scripts/generate-ios-assets-simple.js",
    "setup:pwa": "npm run generate:icons && npm run generate:ios-assets",
    "validate:env": "node scripts/validate-env.js"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.105.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@types/html2canvas": "^1.0.0",
    "@types/node": "20.14.9",
    "@types/react": "18.3.3",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "18.3.0",
    "@vapi-ai/server-sdk": "^0.10.2",
    "@vapi-ai/web": "^2.5.2",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "eslint": "8.57.0",
    "eslint-config-next": "^15.0.0",
    "framer-motion": "^11.2.12",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.2.4",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "ngrok": "^5.0.0-beta.2",
    "postcss": "^8.5.10",
    "react": "18.3.1",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^4.10.0",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "6.0.3",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.2.2",
    "@types/web-push": "^3.6.4",
    "audit-ci": "^6.6.1",
    "encoding": "^0.1.13",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "tsx": "^4.21.0"
  }
}
